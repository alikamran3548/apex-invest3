{
  "version": 2,
  "installCommand": "npm install -g pnpm && pnpm install",
  "buildCommand": "cd artifacts/apex-investor && pnpm install && pnpm run build",
  "outputDirectory": "artifacts/apex-investor/dist",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "destination": "/index.html" }
  ]
}